# NudgeOps Environment Configuration
# Copy this to .env and fill in your values

DATABASE_URL=sqlite+aiosqlite:///./nudgeops.db
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=your-secret-key-here-change-in-production
ENVIRONMENT=development
LOG_LEVEL=INFO

# Bandit tuning
BANDIT_EPSILON=0.15
BANDIT_UCB_ALPHA=1.0

# A/B Testing
AB_TEST_MIN_SAMPLE_SIZE=30
AB_TEST_SIGNIFICANCE_LEVEL=0.05

# Fairness cap (max fraction for one intervention type per user)
MAX_SINGLE_INTERVENTION_SHARE=0.60
